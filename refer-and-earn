<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Satellite Vision Cable Network</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+Bengali:wght@400;600;700;900&family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --green: #006A4E;
    --green-light: #00875f;
    --green-dark: #004d38;
    --green-glow: rgba(0,106,78,0.6);
    --red: #F42A41;
    --red-bright: #FF3D56;
    --red-glow: rgba(244,42,65,0.5);
    --gold: #FFD700;
    --gold-light: #FFE55C;
    --white: #FFFFFF;
    --cream: #FFF8F0;
    --dark: #0a1a14;
  }

  body {
    background: #1a1a2e;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 20px;
    font-family: 'Barlow', sans-serif;
  }

  .poster {
    width: 1080px;
    min-height: 1350px;
    position: relative;
    overflow: hidden;
    border-radius: 0;
    background: var(--dark);
  }

  /* ─── CINEMATIC BACKGROUND ─── */
  .bg-scene {
    position: absolute; inset: 0; z-index: 0;
    background:
      /* sunset sky */
      radial-gradient(ellipse 120% 60% at 50% 0%, #FF6B35 0%, #E8480A 15%, #B8320A 30%, #7A1A0A 50%, transparent 70%),
      /* coastal glow */
      radial-gradient(ellipse 80% 40% at 30% 85%, #006A4E44 0%, transparent 60%),
      radial-gradient(ellipse 60% 30% at 75% 90%, #00453322 0%, transparent 50%),
      /* deep sky */
      linear-gradient(180deg,
        #1A0505 0%,
        #3D1205 8%,
        #6B2810 18%,
        #8B3A15 28%,
        #5A2A20 45%,
        #1A2A1E 65%,
        #0D1F16 80%,
        #061210 100%
      );
  }

  /* City skyline silhouette */
  .skyline {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 380px;
    z-index: 1;
    opacity: 0.55;
  }

  /* Water reflection at bottom */
  .water {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 120px;
    background: linear-gradient(180deg, transparent 0%, #00352288 40%, #001a1066 100%);
    z-index: 2;
  }
  .water::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent 0%, #00875f08 2%, transparent 4%
    );
    animation: waterShimmer 4s ease-in-out infinite alternate;
  }
  @keyframes waterShimmer {
    0% { transform: translateX(0); }
    100% { transform: translateX(8px); }
  }

  /* Overlay for text readability */
  .overlay {
    position: absolute; inset: 0; z-index: 3;
    background: linear-gradient(180deg,
      rgba(0,0,0,0.45) 0%,
      rgba(0,20,14,0.35) 25%,
      rgba(0,30,20,0.2) 50%,
      rgba(0,20,14,0.5) 75%,
      rgba(0,10,8,0.7) 100%
    );
  }

  /* Green vignette band */
  .green-band {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 6px;
    background: linear-gradient(90deg, var(--green-dark), var(--green), var(--green-light), var(--green), var(--green-dark));
    z-index: 20;
    box-shadow: 0 0 30px var(--green-glow), 0 0 60px rgba(0,106,78,0.3);
  }
  .red-band {
    position: absolute;
    top: 6px; left: 0; right: 0;
    height: 3px;
    background: var(--red);
    z-index: 20;
    box-shadow: 0 0 20px var(--red-glow);
  }

  /* ─── CONTENT LAYER ─── */
  .content {
    position: relative;
    z-index: 10;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ═══════════════════════════════
     SECTION 1: HOOK
  ═══════════════════════════════ */
  .hook-section {
    width: 100%;
    padding: 40px 60px 10px;
    text-align: center;
    position: relative;
  }

  .hook-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.95;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .hook-eyebrow::before,
  .hook-eyebrow::after {
    content: '';
    height: 1px;
    width: 60px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .hook-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 112px;
    line-height: 0.92;
    letter-spacing: 4px;
    color: var(--white);
    text-transform: uppercase;
    -webkit-text-stroke: 1px rgba(255,255,255,0.1);
    filter: drop-shadow(0 0 40px rgba(0,0,0,0.8));
    position: relative;
  }
  .hook-headline .word-refer { color: var(--white); }
  .hook-headline .word-amp { color: var(--gold); font-size: 96px; }
  .hook-headline .word-get { color: var(--white); }
  .hook-headline .word-rewarded {
    color: var(--red-bright);
    -webkit-text-stroke: 1px rgba(255,61,86,0.3);
    text-shadow:
      0 0 30px rgba(255,61,86,0.8),
      0 0 60px rgba(255,61,86,0.4),
      0 4px 0 rgba(120,0,20,0.9);
    display: block;
  }

  .hook-subline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 18px;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.75);
    margin-top: 10px;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════
     SECTION 2: MAIN OFFER BADGE
  ═══════════════════════════════ */
  .offer-badge-wrap {
    width: 100%;
    padding: 20px 60px;
    display: flex;
    justify-content: center;
    position: relative;
  }

  .offer-badge {
    position: relative;
    background: linear-gradient(135deg,
      rgba(180,0,30,0.95) 0%,
      rgba(220,20,50,0.98) 40%,
      rgba(200,10,40,0.95) 100%
    );
    border: 2px solid rgba(255,100,120,0.5);
    border-radius: 20px;
    padding: 28px 50px 24px;
    text-align: center;
    box-shadow:
      0 0 50px rgba(244,42,65,0.6),
      0 0 100px rgba(244,42,65,0.3),
      inset 0 1px 0 rgba(255,200,200,0.3),
      0 20px 60px rgba(0,0,0,0.5);
    max-width: 780px;
    width: 100%;
    overflow: hidden;
  }

  .offer-badge::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 50%);
    border-radius: inherit;
  }

  /* Diagonal ribbon */
  .badge-ribbon {
    position: absolute;
    top: 22px; right: -35px;
    background: var(--gold);
    color: var(--dark);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 13px;
    letter-spacing: 2px;
    padding: 6px 50px;
    transform: rotate(30deg);
    text-transform: uppercase;
    box-shadow: 0 4px 15px rgba(0,0,0,0.4);
  }

  .badge-top-line {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 5px;
    color: rgba(255,220,220,0.85);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .badge-main {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 88px;
    line-height: 1;
    color: var(--white);
    text-shadow: 0 4px 0 rgba(0,0,0,0.4), 0 0 30px rgba(255,220,220,0.3);
    letter-spacing: 3px;
  }
  .badge-main .taka { font-size: 64px; vertical-align: middle; }

  .badge-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 10px 0;
    justify-content: center;
  }
  .badge-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,220,220,0.5), transparent);
  }
  .badge-divider-plus {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--gold);
    text-shadow: 0 0 15px var(--gold);
  }

  .badge-secondary {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 34px;
    color: var(--gold-light);
    letter-spacing: 2px;
    text-shadow: 0 0 20px rgba(255,215,0,0.6);
    text-transform: uppercase;
  }

  .badge-months {
    font-family: 'Barlow', sans-serif;
    font-size: 15px;
    color: rgba(255,220,220,0.7);
    margin-top: 4px;
    letter-spacing: 1px;
  }

  /* ═══════════════════════════════
     SECTION 3: OFFER CARDS
  ═══════════════════════════════ */
  .offers-section {
    width: 100%;
    padding: 10px 45px 10px;
  }

  .offers-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 5px;
    color: var(--gold);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 14px;
    opacity: 0.9;
  }

  .offers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .offer-card {
    background: linear-gradient(145deg,
      rgba(0,80,56,0.75) 0%,
      rgba(0,55,38,0.85) 100%
    );
    border: 1px solid rgba(0,180,120,0.25);
    border-radius: 16px;
    padding: 20px 18px 18px;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(10px);
    box-shadow:
      0 8px 32px rgba(0,0,0,0.4),
      inset 0 1px 0 rgba(0,200,140,0.2);
    transition: transform 0.2s;
  }

  .offer-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    border-radius: 16px 16px 0 0;
  }
  .offer-card:nth-child(1)::before { background: linear-gradient(90deg, var(--gold), #FFAA00); box-shadow: 0 0 15px var(--gold); }
  .offer-card:nth-child(2)::before { background: linear-gradient(90deg, var(--red), #FF6080); box-shadow: 0 0 15px var(--red); }
  .offer-card:nth-child(3)::before { background: linear-gradient(90deg, #00C88A, #00FF99); box-shadow: 0 0 15px #00C88A; }

  .card-icon {
    font-size: 36px;
    margin-bottom: 10px;
    display: block;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));
  }

  .card-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .offer-card:nth-child(1) .card-label { color: var(--gold); }
  .offer-card:nth-child(2) .card-label { color: #FF8090; }
  .offer-card:nth-child(3) .card-label { color: #00E898; }

  .card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 26px;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 6px;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .card-desc {
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.75);
    line-height: 1.5;
  }
  .card-desc strong { color: var(--white); font-weight: 600; }

  /* ═══════════════════════════════
     SECTION 4: VISUAL TRUST SCENE
  ═══════════════════════════════ */
  .scene-section {
    width: 100%;
    padding: 18px 60px 10px;
    display: flex;
    justify-content: center;
  }

  .scene-container {
    width: 100%;
    max-width: 940px;
    background: linear-gradient(135deg,
      rgba(0,60,42,0.5) 0%,
      rgba(0,40,28,0.4) 100%
    );
    border: 1px solid rgba(0,200,140,0.15);
    border-radius: 24px;
    padding: 28px 36px;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }
  .scene-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(0,106,78,0.2), transparent);
  }

  .scene-inner {
    display: flex;
    align-items: center;
    gap: 30px;
    position: relative;
    z-index: 2;
  }

  /* People illustration */
  .people-area {
    flex: 0 0 340px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .people-svg-wrap {
    width: 320px;
    height: 200px;
    position: relative;
  }

  /* Network diagram */
  .network-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .network-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--gold);
    text-transform: uppercase;
    opacity: 0.8;
  }

  .network-svg-wrap {
    width: 100%;
    height: 180px;
  }

  /* ═══════════════════════════════
     SECTION 5: BENEFIT LINE
  ═══════════════════════════════ */
  .benefit-section {
    width: 100%;
    padding: 18px 60px 10px;
    text-align: center;
  }

  .benefit-pill {
    display: inline-block;
    background: linear-gradient(135deg, rgba(0,106,78,0.7), rgba(0,70,50,0.8));
    border: 1px solid rgba(0,200,140,0.3);
    border-radius: 50px;
    padding: 14px 40px;
    position: relative;
    box-shadow: 0 0 30px rgba(0,106,78,0.4), inset 0 1px 0 rgba(0,200,140,0.2);
  }

  .benefit-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 21px;
    color: var(--white);
    letter-spacing: 1px;
    line-height: 1.4;
  }
  .benefit-text em {
    font-style: normal;
    color: var(--gold-light);
    font-weight: 700;
  }

  /* ═══════════════════════════════
     SECTION 6: CONDITIONS
  ═══════════════════════════════ */
  .conditions-section {
    width: 100%;
    padding: 14px 60px 20px;
  }

  .conditions-box {
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 16px 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    backdrop-filter: blur(6px);
  }

  .conditions-header {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 4px;
    color: rgba(255,200,100,0.7);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .condition-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
  }
  .condition-item::before {
    content: '•';
    color: var(--red);
    font-size: 16px;
    line-height: 1.3;
    flex-shrink: 0;
  }
  .condition-item strong { color: rgba(255,255,255,0.85); font-weight: 600; }

  /* Bottom band */
  .bottom-band {
    width: 100%;
    height: 9px;
    background: linear-gradient(90deg,
      var(--green-dark) 0%,
      var(--green) 20%,
      var(--white) 40%,
      var(--white) 60%,
      var(--red) 80%,
      var(--red) 100%
    );
    box-shadow: 0 -4px 20px rgba(0,0,0,0.4);
    margin-top: 10px;
  }

  /* ─── AMBIENT PARTICLES ─── */
  .particle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 4;
    animation: floatParticle linear infinite;
  }
  @keyframes floatParticle {
    0% { transform: translateY(0) scale(1); opacity: var(--op); }
    50% { opacity: calc(var(--op) * 1.5); }
    100% { transform: translateY(-120px) scale(0.5); opacity: 0; }
  }

  /* Scanline effect */
  .scanlines {
    position: absolute; inset: 0; z-index: 5; pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.04) 2px,
      rgba(0,0,0,0.04) 4px
    );
  }

  /* Glow orbs */
  .glow-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
    z-index: 2;
  }
</style>
</head>
<body>
<div class="poster">

  <!-- Background scene -->
  <div class="bg-scene"></div>

  <!-- Glow orbs for atmosphere -->
  <div class="glow-orb" style="width:500px;height:400px;top:-100px;left:-100px;background:rgba(255,100,40,0.18);"></div>
  <div class="glow-orb" style="width:400px;height:300px;top:200px;right:-80px;background:rgba(0,106,78,0.2);"></div>
  <div class="glow-orb" style="width:600px;height:300px;bottom:200px;left:50%;transform:translateX(-50%);background:rgba(0,70,50,0.3);"></div>

  <!-- City skyline SVG -->
  <svg class="skyline" viewBox="0 0 1080 380" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMax meet">
    <defs>
      <linearGradient id="bldg" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#1a3a2a" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#0a1a12" stop-opacity="1"/>
      </linearGradient>
      <filter id="glow2">
        <feGaussianBlur stdDeviation="2" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>
    <!-- Background hills -->
    <ellipse cx="540" cy="380" rx="700" ry="120" fill="#0a1810" opacity="0.8"/>
    <!-- Buildings far back -->
    <rect x="20" y="220" width="40" height="160" fill="url(#bldg)" opacity="0.6"/>
    <rect x="65" y="190" width="55" height="190" fill="url(#bldg)" opacity="0.6"/>
    <rect x="125" y="230" width="35" height="150" fill="url(#bldg)" opacity="0.5"/>
    <rect x="165" y="170" width="45" height="210" fill="url(#bldg)" opacity="0.7"/>
    <rect x="215" y="200" width="60" height="180" fill="url(#bldg)" opacity="0.6"/>
    <rect x="280" y="150" width="50" height="230" fill="url(#bldg)" opacity="0.75"/>
    <rect x="335" y="210" width="38" height="170" fill="url(#bldg)" opacity="0.5"/>
    <rect x="378" y="180" width="70" height="200" fill="url(#bldg)" opacity="0.65"/>
    <rect x="455" y="140" width="45" height="240" fill="url(#bldg)" opacity="0.8"/>
    <rect x="505" y="195" width="55" height="185" fill="url(#bldg)" opacity="0.6"/>
    <rect x="565" y="165" width="48" height="215" fill="url(#bldg)" opacity="0.7"/>
    <rect x="620" y="130" width="65" height="250" fill="url(#bldg)" opacity="0.8"/>
    <rect x="690" y="175" width="42" height="205" fill="url(#bldg)" opacity="0.6"/>
    <rect x="738" y="195" width="55" height="185" fill="url(#bldg)" opacity="0.55"/>
    <rect x="800" y="160" width="50" height="220" fill="url(#bldg)" opacity="0.7"/>
    <rect x="855" y="185" width="40" height="195" fill="url(#bldg)" opacity="0.6"/>
    <rect x="900" y="145" width="60" height="235" fill="url(#bldg)" opacity="0.75"/>
    <rect x="965" y="200" width="45" height="180" fill="url(#bldg)" opacity="0.55"/>
    <rect x="1015" y="170" width="65" height="210" fill="url(#bldg)" opacity="0.65"/>
    <!-- Windows (warm lights) -->
    <rect x="172" y="182" width="5" height="4" fill="#FFD080" opacity="0.7"/>
    <rect x="182" y="195" width="5" height="4" fill="#FFD080" opacity="0.5"/>
    <rect x="292" y="160" width="5" height="4" fill="#FFD080" opacity="0.8"/>
    <rect x="302" y="175" width="5" height="4" fill="#FFAA40" opacity="0.6"/>
    <rect x="312" y="160" width="5" height="4" fill="#FFD080" opacity="0.4"/>
    <rect x="462" y="150" width="5" height="4" fill="#FFD080" opacity="0.9"/>
    <rect x="472" y="165" width="5" height="4" fill="#FFAA40" opacity="0.7"/>
    <rect x="462" y="178" width="5" height="4" fill="#FFD080" opacity="0.6"/>
    <rect x="630" y="140" width="5" height="4" fill="#FFD080" opacity="0.8"/>
    <rect x="643" y="155" width="5" height="4" fill="#FFAA40" opacity="0.9"/>
    <rect x="656" y="140" width="5" height="4" fill="#FFD080" opacity="0.5"/>
    <rect x="630" y="168" width="5" height="4" fill="#FFD080" opacity="0.7"/>
    <rect x="910" y="155" width="5" height="4" fill="#FFD080" opacity="0.8"/>
    <rect x="923" y="170" width="5" height="4" fill="#FFAA40" opacity="0.6"/>
    <rect x="936" y="155" width="5" height="4" fill="#FFD080" opacity="0.7"/>
    <!-- Mosque silhouette -->
    <polygon points="500,140 510,100 520,140" fill="#0d2018" opacity="0.85"/>
    <rect x="498" y="138" width="24" height="55" fill="#0d2018" opacity="0.85"/>
